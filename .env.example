# ============================================================
# VARIABLES D'ENVIRONNEMENT - Solimouv' PWA
# ============================================================
# Copier ce fichier en .env.local et renseigner vos valeurs.
# IMPORTANT : Ne jamais committer le fichier .env.local !
# ============================================================

# --- Firebase Configuration ---
# Récupérez ces valeurs dans Firebase Console :
# Paramètres du projet → Vos applications → SDK Firebase

VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# --- Mode Application ---
# "development" | "production"
VITE_APP_ENV=development


# --- Webhook Make (Sport Matcher) ---
# URL du scénario Make pour les demandes de contact associations
# Laisser vide ou "a_configurer" pour désactiver silencieusement
VITE_MAKE_WEBHOOK_CONTACT=a_configurer

VITE_MAKE_WEBHOOK_RAPPEL=a_configurer
